`ifndef SMPB_PKG_VH
`define SMPB_PKG_VH

////////////////////////////////////////////////////////////
// SMPB Configuration
////////////////////////////////////////////////////////////

`define SMPB_ADDR_WIDTH 32
`define SMPB_DATA_WIDTH 32

////////////////////////////////////////////////////////////
// Peripheral IDs
////////////////////////////////////////////////////////////

`define SMPB_SRAM   0
`define SMPB_CGRA   1
`define SMPB_UART   2
`define SMPB_GPIO   3
`define SMPB_TIMER  4

`define SMPB_NUM_SLAVES 5

////////////////////////////////////////////////////////////
// Base Address (upper 16 bits)
////////////////////////////////////////////////////////////

`define SRAM_BASE   16'h0000
`define CGRA_BASE   16'h0001
`define UART_BASE   16'h0002
`define GPIO_BASE   16'h0003
`define TIMER_BASE  16'h0004

////////////////////////////////////////////////////////////

`endif