`ifndef SMPB_BUS_PKG_VH
`define SMPB_BUS_PKG_VH

///////////////////////////////////////////////////////////////
// SMPB Bus Package
///////////////////////////////////////////////////////////////

`define SMPB_VERSION        32'h00010000

///////////////////////////////////////////////////////////////
// Response
///////////////////////////////////////////////////////////////

`define SMPB_RESP_OKAY      2'b00
`define SMPB_RESP_ERROR     2'b01
`define SMPB_RESP_TIMEOUT   2'b10

///////////////////////////////////////////////////////////////
// Bus Types
///////////////////////////////////////////////////////////////

`define SMPB_READ           1'b0
`define SMPB_WRITE          1'b1

///////////////////////////////////////////////////////////////
// Peripheral Count
///////////////////////////////////////////////////////////////

`define SMPB_NUM_SLAVES     4

///////////////////////////////////////////////////////////////

`endif