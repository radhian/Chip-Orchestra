`ifndef NANO_SOC_PKG_VH
`define NANO_SOC_PKG_VH

///////////////////////////////////////////////////////////////
// NanoCGRA-SoC
//
// Global SoC Definitions
//
// Target : GF180MCU
// CPU    : FAZYRV RV32I
// Bus    : SMPB
///////////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////////
// Bus Width
///////////////////////////////////////////////////////////////

`define SOC_ADDR_WIDTH      32
`define SOC_DATA_WIDTH      32

///////////////////////////////////////////////////////////////
// Clock
///////////////////////////////////////////////////////////////

`define SYSTEM_CLOCK_HZ     20000000

///////////////////////////////////////////////////////////////
// Memory Map
///////////////////////////////////////////////////////////////

`define SRAM_BASE_ADDR      32'h0000_0000
`define SRAM_END_ADDR       32'h0000_03FF

`define CGRA_BASE_ADDR      32'h0001_0000
`define CGRA_END_ADDR       32'h0001_00FF

`define UART_BASE_ADDR      32'h0002_0000
`define UART_END_ADDR       32'h0002_00FF

`define GPIO_BASE_ADDR      32'h0003_0000
`define GPIO_END_ADDR       32'h0003_00FF

`define TIMER_BASE_ADDR     32'h0004_0000
`define TIMER_END_ADDR      32'h0004_00FF

///////////////////////////////////////////////////////////////
// Interrupt Numbers
///////////////////////////////////////////////////////////////

`define IRQ_UART            0
`define IRQ_TIMER           1
`define IRQ_GPIO            2

///////////////////////////////////////////////////////////////

`endif