# Yosys synthesis script for NanoCGRA_Lite OPT (3x3+32B, 4-pin UART) -> gf180mcu_fd_sc_mcu7t5v0

# ---- Read RTL (params.vh via -I) ----
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/sram.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/pe.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/cgra.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/uart.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/bus_decoder.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/nano_controller.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/uart_bridge.v
read_verilog -I output/nanocgra_lite_3x3_opt/rtl output/nanocgra_lite_3x3_opt/rtl/nanocgra_lite.v

# ---- Elaborate ----
hierarchy -top NanoCGRA_Lite
synth -top NanoCGRA_Lite -flatten

# ---- Technology mapping ----
dfflibmap -liberty /workspace/iris_c3a247b9-0025-43e1-bae8-42a940fa0b63/.pdk/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu7t5v0/lib/gf180mcu_fd_sc_mcu7t5v0__tt_025C_5v00.lib
abc -liberty /workspace/iris_c3a247b9-0025-43e1-bae8-42a940fa0b63/.pdk/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu7t5v0/lib/gf180mcu_fd_sc_mcu7t5v0__tt_025C_5v00.lib -D 100000

# ---- Cleanup ----
setundef -zero
hilomap -hicell gf180mcu_fd_sc_mcu7t5v0__tieh Z -locell gf180mcu_fd_sc_mcu7t5v0__tiel ZN
splitnets
opt_clean

# ---- Write netlist ----
write_verilog -noattr output/nanocgra_lite_3x3_opt/synth/nanocgra_lite_3x3_opt.synth.v

# ---- Reports ----
tee -o output/nanocgra_lite_3x3_opt/reports/synth_stat.txt stat -liberty /workspace/iris_c3a247b9-0025-43e1-bae8-42a940fa0b63/.pdk/gf180mcuD/libs.ref/gf180mcu_fd_sc_mcu7t5v0/lib/gf180mcu_fd_sc_mcu7t5v0__tt_025C_5v00.lib
