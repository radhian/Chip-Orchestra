# ---------------------------------------------------------------------------
# Chip Orchestra backend configuration
# Copy to .env and adjust. All values have sensible defaults for local dev.
# ---------------------------------------------------------------------------

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
# Comma-separated origins allowed to call the API (the Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM provider ---
# ollama (default, fully local) | gemini (requires the `gemini` extra + key)
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
# Already pulled on this machine: qwen3.5:9b, gds-qwen35-4b, glm-5:cloud
OLLAMA_MODEL=qwen3.5:9b
LLM_TEMPERATURE=0.2
# Qwen3 deep "thinking": higher quality but ~minutes per step. Default ON for
# best RTL quality. Set false to append /no_think for faster, shallower runs.
OLLAMA_THINK=true
# Context + output budget. Ollama's tiny ~4k default truncates the code after a
# long <think> block. 32k fits reasoning + RTL on an 8GB GPU (KV cache spills to
# RAM, slower but works); drop to 16384 if you hit memory pressure.
OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=-1
# Optional Gemini fallback (only used when LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Agent behaviour ---
# Max self-correction iterations of the simulate -> fix -> resimulate loop.
MAX_RETRIES=3
# Web research: pull real Verilog from GitHub repos + filtered web/papers
# (crawl4ai), then RAG-rank with sentence-transformers + FAISS into the generator.
USE_WEB=true
USE_RAG=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Per-task "Research depth" slider (SMALL=3+3, MEDIUM=6+6, DEEP=10+10 GitHub+web)
# scales these at runtime. Optional GitHub token raises API rate limits.
# GITHUB_TOKEN=
WEB_TIMEOUT_SEC=25
RAG_CHUNK_CHARS=1400
REFERENCE_CHAR_BUDGET=6000
RAG_INDEX_DIR=

# --- EDA tools ---
# Icarus Verilog (already installed: iverilog 11.0).
IVERILOG_BIN=iverilog
VVP_BIN=vvp
SIM_TIMEOUT_SEC=120

# LibreLane hardening (RTL -> GDSII). Leave RUN_HARDEN=true to attempt it.
RUN_HARDEN=true
# Command used to invoke LibreLane. The flow falls back gracefully if missing.
# Examples:
#   LIBRELANE_CMD=librelane
#   LIBRELANE_CMD=nix run github:librelane/librelane --
LIBRELANE_CMD=librelane
HARDEN_TIMEOUT_SEC=3600
DEFAULT_PDK=sky130A
DEFAULT_STDCELL=sky130_fd_sc_hd

# --- Storage ---
# Local working cache for task metadata + generated workspaces (rtl/, tb/, sim/, gds/).
WORKSPACE_ROOT=./.workspaces

# --- Durable persistence (optional, config-driven) ---
# 100% FREE + LOCAL. Postgres and MinIO both run on YOUR machine via Docker
# (docker-compose.yml) and store data on your local disk. MinIO is self-hosted,
# free, S3-API-compatible object storage — it is NOT AWS S3, there is no cloud
# bill. "S3" below just means the protocol; the endpoint is localhost.
#
# To run with NO Docker and NO database at all (pure local file store under
# WORKSPACE_ROOT), simply comment out DATABASE_URL + the S3_* lines below.
DATABASE_URL=postgresql+psycopg://chip:chip@localhost:5432/chiporchestra
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=chip
S3_SECRET_KEY=chipsecret
S3_BUCKET=chiporchestra
S3_REGION=us-east-1
