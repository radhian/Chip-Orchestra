COMPOSE_PROJECT_NAME=chip-orchestra
MYSQL_DATABASE=chip_orchestra
MYSQL_USER=chip
MYSQL_PASSWORD=chip
MYSQL_ROOT_PASSWORD=chiproot
MYSQL_PORT=3306
REDIS_PORT=6379
OPERATOR_PORT=8080
AGENT_PORT=8001
EDA_PORT=8002
FRONTEND_PORT=4173
JWT_SECRET=chip-orchestra-secret
DEFAULT_USERNAME=admin
DEFAULT_FULL_NAME=Admin Admin
DEFAULT_EMAIL=admin@chip-orchestra.local
DEFAULT_PASSWORD=chip-orchestra

# --- Shared workspace ---
# Root directory for per-task workspaces (rtl/, tb/, reports/, logs/, waves/,
# gds/, context/, exports/). Shared by the orchestrator, eda-service and
# agent-service so evidence produced by one stage is visible to the next.
WORKSPACE_ROOT=/tmp/chip-orchestra/workspaces

# --- EDA service (RTL simulation + LibreLane hardening) ---
# Tool binaries resolve from *_PATH first, then *_BIN, then PATH defaults.
IVERILOG_PATH=
VVP_PATH=
LIBRELANE_PATH=
IVERILOG_BIN=iverilog
VVP_BIN=vvp
LIBRELANE_BIN=librelane
PDK=sky130A
PDK_ROOT=/opt/pdk
EDA_JOB_TIMEOUT_SIM=600
EDA_JOB_TIMEOUT_HARDEN=3600

# --- Agent service (evidence-backed stage handlers + reporting) ---
# Defaults to WORKSPACE_ROOT when unset.
AGENT_ARTIFACT_ROOT=/tmp/chip-orchestra/workspaces
LLM_PROVIDER=mock
MODEL_NAME=mock-deterministic
MAX_CONTEXT_TOKENS=8192