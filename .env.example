COMPOSE_PROJECT_NAME=chip-orchestra
MYSQL_DATABASE=chip_orchestra
MYSQL_USER=chip
MYSQL_PASSWORD=chip
MYSQL_ROOT_PASSWORD=chiproot
MYSQL_PORT=3306
REDIS_PORT=6379
OPERATOR_PORT=8080
AGENT_PORT=8001
EDA_PORT=8002
FRONTEND_PORT=4173
JWT_SECRET=chip-orchestra-secret
DEFAULT_USERNAME=admin
DEFAULT_FULL_NAME=Admin Admin
DEFAULT_EMAIL=admin@chip-orchestra.local
DEFAULT_PASSWORD=chip-orchestra

# --- Shared workspace ---
# Root directory for per-task workspaces (rtl/, tb/, reports/, logs/, waves/,
# gds/, context/, exports/). Shared by the orchestrator, eda-service and
# agent-service so evidence produced by one stage is visible to the next.
WORKSPACE_ROOT=/tmp/chip-orchestra/workspaces

# --- EDA service (RTL simulation + LibreLane hardening + STA + renders) ---
# Tool binaries resolve from *_PATH first, then *_BIN, then PATH defaults.
IVERILOG_PATH=iverilog
VVP_PATH=vvp
LIBRELANE_PATH=librelane
IVERILOG_BIN=iverilog
VVP_BIN=vvp
LIBRELANE_BIN=librelane
YOSYS_BIN=yosys
STA_BIN=sta
KLAYOUT_BIN=klayout
DOT_PATH=dot
# Default PDK is GF180MCU (matches the manual NanoCGRA-Lite flow). Volare
# auto-installs it into PDK_ROOT on first eda-service boot if not present.
PDK=gf180mcuD
PDK_ROOT=/opt/pdk
EDA_JOB_TIMEOUT_SIM=600
EDA_JOB_TIMEOUT_HARDEN=3600
EDA_JOB_TIMEOUT_STA=900
EDA_JOB_TIMEOUT_GL_SIM=900

# --- LLM provider (agent-service) ---
# Selected by LLM_PROVIDER: ollama | google | openai/glm | mock
#
# Option A (DEFAULT): Ollama (install https://ollama.com).
# Default model is the Ollama CLOUD model glm-5.2:cloud — inference runs on
# Ollama's servers (no GPU needed): run `ollama signin` once, then
# `ollama pull glm-5.2:cloud`. Any local model works too, e.g.
# `ollama pull qwen3.5:9b` and set OLLAMA_MODEL accordingly.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=glm-5.2:cloud
# How long, in seconds, to wait for a single generation.
OLLAMA_TIMEOUT=600
# Context window. Ollama DEFAULTS to 2048 regardless of the model's real window,
# which truncates the prompt and makes the model return nothing — so we set it.
# KV cache ≈ 56 KB/token for a 9B model: 16k≈0.9 GB, 32k≈1.8 GB, 128k≈7 GB.
# The ceiling is your RAM/VRAM, not the model.
OLLAMA_NUM_CTX=32768
# Thinking pass (qwen3). 1 = enable the model's reasoning pass (slower, often
# better on hard designs) · 0 = off (content streams immediately).
OLLAMA_THINK=1
# Anti-repetition / runaway-generation guards for small local models.
OLLAMA_REPEAT_PENALTY=1.18
OLLAMA_REPEAT_LAST_N=256
OLLAMA_NUM_PREDICT=8192
#
# Option B: OpenAI-compatible endpoint — ZhipuAI GLM (e.g. GLM-4.6 / GLM-5.2).
# LLM_PROVIDER=glm
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_API_KEY=your-zhipuai-key
# OPENAI_MODEL=glm-4.6
#
# Option C: Google Gemini (cloud, requires API key)
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-2.5-pro
#
# Option D: mock (deterministic, no external dependencies — CI/local without keys)
# LLM_PROVIDER=mock

# --- Vision (image upload → block-diagram understanding) ---
# Attached images are read by a VISION model into a structural spec (blocks,
# labels, bit-widths, connections) that drives RTL generation. The vision model
# is DECOUPLED from the chat model: if the chat model can't see images, the
# first installed local Ollama VLM (e.g. qwen3.5:9b, llava, minicpm-v) is used.
# Force a specific one, or force vision on/off:
# GARUDA_VISION_MODEL=qwen3.5:9b
# GARUDA_VISION=1
# Keep the vision call's context modest so the VLM's KV cache fits tight VRAM.
OLLAMA_VISION_NUM_CTX=8192
OLLAMA_VISION_TIMEOUT=240

# --- RLM deep agents (agent-service) ---
# Every LLM stage (PLAN / RTL_GEN / RTL_REPAIR / TB_GEN) runs a deep agent with
# real file tools (compile-check-on-write), an llm_query delegation primitive,
# a Python sandbox, web research and fix-lesson memory. Set 0 to fall back to
# the one-shot templated generation.
AGENT_DEEP_AGENTS=1
# Wall-clock budget for one deep-agent session (seconds).
GARUDA_DEEP_BUDGET_S=2400
# Timeout for one run_python sandbox snippet (seconds).
GARUDA_PY_TIMEOUT_S=600
# Where the agents' pip_install tool puts packages — a directory on the shared
# workspace volume, so installs PERSIST across container restarts/rebuilds and
# are shared by every task (default: <WORKSPACE_ROOT>/.pydeps).
# AGENT_PYDEPS_DIR=/tmp/chip-orchestra/workspaces/.pydeps

# --- Web research (agent-service) ---
# The agents can FIND INFORMATION ONLINE: search a design topic or an error
# message, fetch reference HDL from GitHub, and anchor the plan on the closest
# open-source design. Set 0 to disable all outbound research.
AGENT_WEB_RESEARCH=1
# Optional self-hosted SearXNG metasearch instance (primary search backend;
# DuckDuckGo + the GitHub API are used when unset/unreachable).
# SEARXNG_URL=http://localhost:8888
# Optional GitHub token to avoid API rate limits during the reference hunt.
# GITHUB_TOKEN=
# Budgets so research can never stall the pipeline (seconds).
GARUDA_RESEARCH_BUDGET_S=420
GARUDA_CLONE_TIMEOUT_S=90

# Max iverilog compile-check auto-repair rounds during RTL generation.
MAX_REPAIR_ITERS=3

# How long the orchestrator waits for one synchronous agent-service call
# (LLM planning / RTL / TB generation). Large briefs on slower models can
# legitimately need many minutes.
AGENT_INVOKE_TIMEOUT_SECONDS=1800

AGENT_ARTIFACT_ROOT=/tmp/chip-orchestra/workspaces

MAX_CONTEXT_TOKENS=8192